<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VESTA · Az — AI Interior Design Studio</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/interactjs/dist/interact.min.js"></script>
<script src="https://html2canvas.hertzen.com/dist/html2canvas.min.js"></script>
<style>
:root {
  --ink:#1A1614; --ink2:#352C26; --cream:#F5F0E8; --cream2:#EDE5D6; --cream3:#E4D9C8;
  --stone:#B0A394; --taupe:#857568; --accent:#A87048; --accent2:#C8926A;
  --surface:#FDFAF5; --border:rgba(133,117,104,0.16); --border2:rgba(133,117,104,0.28);
  --green:#4A7A58; --red:#9C2E2E; --red-bg:#FBF0F0;
  --radius:6px; --radius-lg:12px;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'DM Sans',sans-serif;background:var(--cream);color:var(--ink);min-height:100vh;font-weight:300;font-size:14px;}

/* ── HEADER ── */
header{height:54px;background:var(--ink);display:flex;align-items:center;justify-content:space-between;padding:0 36px;position:sticky;top:0;z-index:200;}
.logo{font-family:'Cormorant Garamond',serif;font-size:20px;color:var(--cream);font-weight:300;letter-spacing:.06em;}
.logo em{color:#C8926A;font-style:italic;}
.logo-sub{font-size:11px;color:rgba(200,146,106,.6);letter-spacing:.12em;margin-left:14px;}
.api-input{background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.15); border-radius:4px; padding:6px 10px; color:#fff; font-size:12px; outline:none; width:200px; font-family:monospace; transition:all 0.2s;}
.api-input:focus{border-color:var(--accent2); background:rgba(255,255,255,0.12);}

/* ── MODULE TABS ── */
.mod-tabs{display:flex;background:var(--ink2);padding:0 36px;gap:2px;}
.mtab{display:flex;align-items:center;gap:8px;padding:12px 24px;font-size:12px;letter-spacing:.1em;text-transform:uppercase;color:rgba(245,240,232,.4);cursor:pointer;border-bottom:2px solid transparent;transition:all .2s;font-weight:400;}
.mtab:hover{color:rgba(245,240,232,.7);}
.mtab.on{color:var(--accent2);border-bottom-color:var(--accent2);}
.mtab-dot{width:6px;height:6px;border-radius:50%;background:currentColor;opacity:.6;}
.pipeline-arrow{display:flex;align-items:center;padding:0 8px;color:rgba(200,146,106,.3);font-size:16px;align-self:center;}

/* ── MODULE PANELS ── */
.mod-panel{display:none;}
.mod-panel.on{display:block;}

/* ══════════════════════════════════
   MODULE A — HARD DECO
══════════════════════════════════ */
.stepnav{display:flex;background:var(--surface);border-bottom:1px solid var(--border);padding:0 36px;}
.sn{display:flex;align-items:center;gap:8px;padding:14px 28px 14px 0;opacity:.35;transition:opacity .2s;position:relative;cursor:default;}
.sn.active{opacity:1;}
.sn.done{opacity:.6;cursor:pointer;}
.sn.done:hover{opacity:.8;}
.sn::after{content:'';position:absolute;bottom:0;left:0;right:28px;height:2px;}
.sn.active::after{background:var(--accent);}
.sn-dot{width:24px;height:24px;border-radius:50%;border:1.5px solid var(--stone);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:500;color:var(--stone);flex-shrink:0;transition:all .2s;}
.sn.active .sn-dot{border-color:var(--accent);color:var(--accent);}
.sn.done .sn-dot{background:var(--green);border-color:var(--green);color:white;font-size:10px;}
.sn-label{font-size:12px;color:var(--taupe);white-space:nowrap;}
.sn.active .sn-label{color:var(--ink);font-weight:400;}
.sn-sep{width:28px;height:1px;background:var(--border2);align-self:center;flex-shrink:0;}

.main-a{max-width:960px;margin:0 auto;padding:36px 36px 100px;}
.page{display:none;animation:fi .22s ease;}
.page.active{display:block;}
@keyframes fi{from{opacity:0;transform:translateY(5px)}to{opacity:1;transform:translateY(0)}}

.slabel{font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--taupe);margin-bottom:12px;font-weight:400;}
.info{background:rgba(168,112,72,.07);border:1px solid rgba(168,112,72,.2);border-radius:4px;padding:12px 16px;font-size:12.5px;color:var(--taupe);line-height:1.75;margin-bottom:24px;}
.info strong{color:var(--accent);}

/* UPLOAD */
.upload-pair{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:28px;}
.ucard{border:1px solid var(--border);border-radius:6px;overflow:hidden;background:var(--surface);}
.uhead{padding:11px 16px;border-bottom:1px solid var(--border);background:var(--cream2);display:flex;align-items:center;gap:8px;}
.ubadge{width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:500;flex-shrink:0;}
.uname{font-size:13px;font-weight:500;}
.uhint{font-size:11px;color:var(--taupe);margin-left:auto;}
.dropzone{min-height:190px;display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;position:relative;overflow:hidden;background:var(--cream);padding:22px;transition:background .2s;text-align:center;}
.dropzone:hover{background:rgba(168,112,72,.04);}
.dropzone input{position:absolute;inset:0;opacity:0;cursor:pointer;}
.dropzone img.thumb{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:none;}
.dz-ov{position:absolute;inset:0;background:rgba(26,22,20,.42);display:none;align-items:center;justify-content:center;font-size:11px;color:white;letter-spacing:.1em;text-transform:uppercase;}
.dropzone:hover .dz-ov.on{display:flex;}
.dz-icon{opacity:.25;margin-bottom:9px;}
.dz-title{font-family:'Cormorant Garamond',serif;font-size:16px;font-weight:300;color:var(--ink2);margin-bottom:3px;}
.dz-sub{font-size:11px;color:var(--stone);}
.dz-ok{font-size:11px;color:var(--green);margin-top:6px;font-weight:400;}

/* SETTINGS & PILLS */
.settings-row{display:grid;grid-template-columns:160px 1fr;gap:14px;margin-bottom:22px;}
.field label{display:block;font-size:10px;letter-spacing:.18em;text-transform:uppercase;color:var(--taupe);margin-bottom:7px;}
.field select,.field textarea{width:100%;border:1px solid var(--border);background:var(--cream);border-radius:4px;padding:9px 12px;font-family:'DM Sans',sans-serif;font-size:13px;color:var(--ink2);font-weight:300;outline:none;transition:border-color .2s;}
.field select{height:40px;cursor:pointer;}
.field select:focus,.field textarea:focus{border-color:var(--accent);}
.field textarea{resize:none;}

.pill-wrap{margin-bottom:24px;}
.pills{display:flex;flex-wrap:wrap;gap:6px;margin-top:8px;}
.pill, .spill{border:1px solid var(--border2);border-radius:20px;padding:4px 13px;font-size:12px;color:var(--taupe);cursor:pointer;transition:all .18s;background:transparent;}
.pill:hover{border-color:var(--accent);color:var(--accent);}
.pill.on{background:var(--accent);border-color:var(--accent);color:white;}
.spill:hover{border-color:var(--red);color:var(--red);}
.spill.on{background:var(--red-bg);border-color:var(--red);color:var(--red);}

/* CTA */
.cta-row{display:flex;justify-content:flex-end;gap:10px;margin-top:8px;align-items:center;}
.btn{display:inline-flex;align-items:center;gap:8px;padding:11px 26px;border-radius:4px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:400;cursor:pointer;transition:all .2s;letter-spacing:.03em;border:none;}
.btn-pri{background:var(--ink);color:var(--cream);}
.btn-pri:hover{background:var(--ink2);}
.btn-sec{background:transparent;color:var(--taupe);border:1px solid var(--border2);}
.btn-sec:hover{border-color:var(--taupe);color:var(--ink2);}
.btn-accent{background:var(--accent);color:white;border:none;}
.btn-accent:hover{background:var(--ink);}

/* OUTPUT & TEXTAREA */
.out-card{background:var(--surface);border:1px solid var(--border);border-radius:6px;overflow:hidden;margin-bottom:20px;}
.out-head{background:var(--ink);padding:15px 22px;display:flex;align-items:center;justify-content:space-between;}
.out-title{font-family:'Cormorant Garamond',serif;font-size:18px;color:var(--cream);font-weight:300;letter-spacing:.04em;}
.out-tag{font-size:10px;background:rgba(200,146,106,.2);color:var(--accent2);padding:2px 9px;border-radius:20px;letter-spacing:.08em;}
.out-body{padding:20px 22px;}
.plabel{font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--accent);margin-bottom:10px;font-weight:400;}

/* API Textareas */
textarea.pbox { width:100%; min-height:220px; resize:vertical; outline:none; font-family:monospace; font-size:12px; line-height:1.6; color:#333; padding:16px; border:1px solid var(--border); border-radius:4px; background:var(--cream); transition:border-color .2s; }
textarea.pbox:focus { border-color:var(--accent); }

.copy-row{display:flex;gap:8px;margin-top:16px;flex-wrap:wrap;align-items:center;}
.cbtn{padding:10px 18px;border-radius:4px;font-size:13px;letter-spacing:.05em;cursor:pointer;font-family:'DM Sans',sans-serif;font-weight:400;transition:all .18s;}
.cbtn.p{background:var(--accent);color:white;border:1px solid var(--accent); box-shadow:0 4px 12px rgba(168,112,72,.2);}
.cbtn.p:hover{background:var(--ink); border-color:var(--ink);}
.cbtn.s{background:transparent;color:var(--taupe);border:1px solid var(--border2);}
.cbtn.s:hover{border-color:var(--taupe);color:var(--ink);}
.cbtn.g{background:var(--green);color:white;border:1px solid var(--green);}
.cbtn.g:hover{background:#3a6047;}

/* RENDER RESULT BOX */
.render-result-box { margin-top:24px; border:1px solid var(--border); padding:16px; background:#fff; border-radius:6px; display:none; box-shadow:0 10px 30px rgba(0,0,0,0.05); }
.render-result-box img { width:100%; height:auto; border-radius:4px; display:block; cursor:zoom-in;}

/* CORRECTIONS */
.corr-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:20px;}
.ci{border:1px solid var(--border);border-radius:4px;padding:11px 13px;cursor:pointer;transition:all .18s;background:var(--cream);}
.ci:hover{border-color:var(--accent);}
.ci.on{border-color:var(--red);background:var(--red-bg);}
.ci-icon{font-size:15px;margin-bottom:4px;}
.ci-name{font-size:12px;font-weight:500;color:var(--ink2);margin-bottom:2px;}
.ci.on .ci-name{color:var(--red);}
.ci-desc{font-size:11px;color:var(--taupe);line-height:1.4;}
.corr-out{display:none;}
.corr-out.show{display:block;}
.divider{height:1px;background:var(--border);margin:28px 0;}

/* ══════════════════════════════════
   MODULE B — SOFT FURNISHING
══════════════════════════════════ */
.main-b{display:grid;grid-template-columns:400px 1fr;gap:24px;padding:24px 36px;max-width:1400px;margin:0 auto;align-items:start;}
.ctrl-panel{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);padding:22px;display:flex;flex-direction:column;gap:20px;box-shadow:0 4px 20px rgba(0,0,0,0.03);}
.sec-title{font-size:10px;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:var(--taupe);margin-bottom:10px;display:flex;align-items:center;gap:8px;}
.sec-title::after{content:'';flex:1;height:1px;background:var(--border);}

.asset-zone, .bg-zone{border:1px dashed var(--border2);border-radius:var(--radius);padding:24px 16px;text-align:center;cursor:pointer;transition:all .2s;background:var(--cream);}
.asset-zone:hover, .bg-zone:hover{border-color:var(--accent);background:rgba(168,112,72,.04);}
.asset-zone p, .bg-zone p{font-size:12px;color:var(--taupe);margin-top:6px;}
.bg-zone{padding:0;}
.bg-zone-inner{padding:18px 16px;display:flex;flex-direction:column;align-items:center;gap:6px;}
.bg-zone-inner .hint{font-size:10px;color:var(--stone);}
.bg-preview-row{display:none;align-items:center;gap:10px;padding:10px 12px;background:rgba(74,122,88,.06);border-top:1px solid var(--border);}
.bg-preview-row img{width:52px;height:36px;object-fit:cover;border-radius:3px;border:1px solid var(--border);}
.bg-preview-row span{font-size:11px;color:var(--taupe);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.bg-use-btn{font-size:11px;padding:4px 10px;border-radius:3px;background:var(--green);color:white;border:none;cursor:pointer;white-space:nowrap;}
.bg-rm-btn{background:none;border:none;color:var(--red);cursor:pointer;font-size:16px;opacity:.6;padding:0 4px;}

.prod-list{display:flex;flex-direction:column;gap:7px;max-height:220px;overflow-y:auto;padding-right:2px;}
.prod-item{display:flex;align-items:center;gap:10px;padding:7px 8px;border:1px solid var(--border);border-radius:var(--radius);background:white;}
.prod-item img{width:38px;height:38px;object-fit:contain;background:white;border-radius:3px;border:1px solid #EEE;flex-shrink:0;}
.prod-meta{display:flex;flex-direction:column;gap:3px;flex:1;min-width:0;}
.prod-meta input{border:none;background:transparent;font-size:12px;color:var(--ink);outline:none;width:100%;font-family:'DM Sans',sans-serif;font-weight:300;}
.prod-meta select{border:none;background:transparent;font-size:10px;color:var(--taupe);outline:none;cursor:pointer;font-family:'DM Sans',sans-serif;padding:0;}
.prod-del{background:none;border:none;color:var(--red);cursor:pointer;font-size:15px;padding:0 6px;opacity:.4;transition:opacity .2s;flex-shrink:0;}
.prod-item:hover .prod-del{opacity:1;}

.fgroup{display:flex;flex-direction:column;gap:5px;}
.fgroup label{font-size:10px;font-weight:500;letter-spacing:.1em;text-transform:uppercase;color:var(--taupe);}
.fgroup select{padding:9px 11px;border:1px solid var(--border);border-radius:var(--radius);font-size:12px;font-family:'DM Sans',sans-serif;outline:none;background:var(--cream);color:var(--ink2);}
.fgroup select:focus{border-color:var(--accent);}

.magic-btn{background:var(--ink);color:var(--cream);border:none;padding:14px;border-radius:var(--radius);font-size:13px;font-weight:400;letter-spacing:.05em;cursor:pointer;transition:all .2s;display:flex;justify-content:center;align-items:center;gap:8px;box-shadow:0 6px 18px rgba(26,22,20,.18);margin-top:8px;}
.magic-btn:hover{background:var(--ink2);transform:translateY(-1px);}

.canvas-container{display:flex;flex-direction:column;align-items:center;gap:16px;}
.canvas-header{width:540px;display:flex;justify-content:space-between;align-items:flex-end;}
.canvas-header h3{font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:300;}
.canvas-header p{font-size:11px;color:var(--taupe);margin-top:2px;}
.canvas-dim{font-size:10px;padding:3px 8px;background:var(--cream2);border-radius:3px;color:var(--ink2);}

.canvas-wrap{position:relative;width:540px;height:720px;background:linear-gradient(160deg,#F8F6F0 0%,#EAE5D9 100%);box-shadow:0 16px 50px rgba(0,0,0,0.08);overflow:hidden;border:1px solid var(--border);}
.canvas-grid-layer{position:absolute;inset:0;background-image:linear-gradient(rgba(0,0,0,0.025) 1px,transparent 1px),linear-gradient(90deg,rgba(0,0,0,0.025) 1px,transparent 1px);background-size:54px 54px;z-index:2;pointer-events:none;}
.bg-item{position:absolute;z-index:3;touch-action:none;user-select:none;cursor:move;}
.bg-item img{width:100%;height:100%;object-fit:cover;display:block;pointer-events:none;}
.bg-item.active{outline:2px dashed rgba(168,112,72,.6);outline-offset:2px;}
.bg-resize-handle{position:absolute;right:-7px;bottom:-7px;width:14px;height:14px;background:var(--taupe);border:2px solid white;border-radius:50%;cursor:nwse-resize;display:none;z-index:20;box-shadow:0 2px 5px rgba(0,0,0,0.2);}
.bg-item.active .bg-resize-handle{display:block;}
.bg-item-label{position:absolute;top:4px;left:4px;font-size:9px;background:rgba(26,22,20,.55);color:white;padding:2px 6px;border-radius:2px;letter-spacing:.06em;pointer-events:none;}

.canvas-item{position:absolute;z-index:10;display:flex;align-items:center;justify-content:center;touch-action:none;user-select:none;}
.canvas-item img{width:100%;height:100%;object-fit:contain;pointer-events:none;filter:drop-shadow(0 10px 20px rgba(0,0,0,0.14));}
.canvas-item.active{outline:2px dashed var(--accent);outline-offset:3px;}
.resize-handle{position:absolute;right:-7px;bottom:-7px;width:14px;height:14px;background:var(--accent);border:2px solid white;border-radius:50%;cursor:nwse-resize;display:none;z-index:20;box-shadow:0 2px 5px rgba(0,0,0,0.2);}
.canvas-item.active .resize-handle{display:block;}

/* PROMPT MODAL */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.55);backdrop-filter:blur(4px);z-index:2000;display:none;justify-content:center;align-items:center;padding:40px;}
.modal-overlay.on{display:flex;}
.modal-box{background:white;width:100%;max-width:880px;max-height:88vh;border-radius:var(--radius-lg);display:flex;flex-direction:column;overflow:hidden;box-shadow:0 24px 80px rgba(0,0,0,0.18);}
.modal-hd{padding:18px 22px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;background:var(--cream2);}
.modal-hd h2{font-family:'Cormorant Garamond',serif;font-size:20px;color:var(--ink2);}
.modal-close{background:none;border:none;font-size:22px;cursor:pointer;color:var(--taupe);}
.modal-body{padding:22px;overflow-y:auto;flex:1;}
.modal-foot{padding:14px 22px;border-top:1px solid var(--border);display:flex;justify-content:flex-end;gap:10px;background:#f9f9f9;}

.size-presets{display:grid;grid-template-columns:repeat(3,1fr);gap:5px;margin-bottom:8px;}
.size-pill{border:1px solid var(--border2);border-radius:4px;padding:6px 4px;text-align:center;cursor:pointer;transition:all .18s;background:transparent;}
.size-pill:hover{border-color:var(--accent);color:var(--accent);}
.size-pill.on{background:var(--accent);border-color:var(--accent);color:white;}
.size-pill-name{font-size:11px;font-weight:500;line-height:1.2;}
.size-pill-ratio{font-size:9px;opacity:.7;margin-top:1px;}
.custom-size-row{display:flex;align-items:center;gap:6px;margin-top:6px;}
.custom-size-row input{flex:1;border:1px solid var(--border);border-radius:4px;padding:7px 9px;font-size:12px;font-family:'DM Sans',sans-serif;background:var(--cream);color:var(--ink2);outline:none;text-align:center;}
.custom-size-row input:focus{border-color:var(--accent);}
.custom-size-row span{font-size:12px;color:var(--taupe);flex-shrink:0;}
.custom-apply-btn{padding:7px 12px;border-radius:4px;background:var(--ink);color:white;border:none;font-size:11px;cursor:pointer;white-space:nowrap;}
.custom-apply-btn:hover{background:var(--ink2);}

.env-edit-btn{display:inline-flex;align-items:center;gap:4px;padding:3px 8px;border-radius:3px;border:1px solid var(--border2);background:transparent;font-size:10px;color:var(--taupe);cursor:pointer;letter-spacing:.04em;transition:all .15s;font-family:'DM Sans',sans-serif;}
.env-edit-btn:hover{border-color:var(--accent);color:var(--accent);}

/* GLOBAL LOADER */
.loader-overlay { position:fixed; inset:0; background:rgba(250,246,240,0.85); z-index:9999; display:none; flex-direction:column; align-items:center; justify-content:center; backdrop-filter:blur(5px); }
.loader-overlay.on { display:flex; }
.spinner { width:46px; height:46px; border:3px solid var(--border2); border-top-color:var(--accent); border-radius:50%; animation:spin 0.8s linear infinite; margin-bottom:18px; }
@keyframes spin { to { transform:rotate(360deg); } }
.loader-text { font-size:14px; color:var(--ink); font-weight:500; letter-spacing:0.1em; }
.loader-sub { font-size:11px; color:var(--taupe); margin-top:8px; }

/* Toast */
.toast{position:fixed;bottom:22px;right:22px;background:var(--ink);color:var(--cream);padding:10px 20px; border-radius:4px; font-size:13px; letter-spacing:.04em; opacity:0; transform:translateY(8px); transition:all .25s; pointer-events:none; z-index:9999; box-shadow:0 10px 30px rgba(0,0,0,0.15);}
.toast.show{opacity:1;transform:translateY(0);}

.bridge-banner{background:linear-gradient(135deg,rgba(74,122,88,.12),rgba(168,112,72,.08));border:1px solid rgba(74,122,88,.2);border-radius:6px;padding:14px 18px;display:flex;align-items:center;gap:14px;margin-bottom:20px;}
.bridge-thumb{width:56px;height:40px;object-fit:cover;border-radius:3px;border:1px solid rgba(74,122,88,.2);display:none;flex-shrink:0;}
.bridge-thumb.show{display:block;}
.bridge-text{flex:1;}
.bridge-text strong{font-size:13px;color:var(--green);font-weight:500;}
.bridge-text p{font-size:11px;color:var(--taupe);margin-top:2px;}
.bridge-clear{background:none;border:none;font-size:18px;color:var(--taupe);cursor:pointer;opacity:.5;}

#spriteCanvas{display:none;}

@media(max-width:960px){
  .main-b{grid-template-columns:1fr;}
  .upload-pair,.settings-row,.corr-grid{grid-template-columns:1fr;}
  .main-a{padding:24px 20px 80px;}
}
</style>
</head>
<body>

<header>
  <div style="display:flex;align-items:baseline;gap:4px;">
