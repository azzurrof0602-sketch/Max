// ══════════════════════════════════
// MODULE B — SOFT FURNISHING
// ══════════════════════════════════
let prods =[];
let zCounter = 100;
let CW = 540, CH = 720;
let bgSrc = null;

function applyPreset(el, w, h) {
  document.querySelectorAll('.size-pill').forEach(p => p.classList.remove('on'));
  el.classList.add('on');
  resizeCanvas(w, h);
}
function resizeCanvas(w, h) {
  CW = w; CH = h;
  const cvs = document.getElementById('renderCanvas');
  cvs.style.width = w + 'px'; cvs.style.height = h + 'px';
  document.getElementById('canvasHeader').style.width = Math.max(w, 200) + 'px';
  document.getElementById('canvasDimLabel').textContent = w + ' × ' + h;
}

// Background handlers
function handleBgUpload(e) {
  const f = e.target.files[0];
  if (!f) return;
  const r = new FileReader();
  r.onload = ev => {
    bgSrc = ev.target.result;
    document.getElementById('bgThumb').src = bgSrc;
    document.getElementById('bgFileName').textContent = f.name;
    document.getElementById('bgPreviewRow').style.display = 'flex';
  };
  r.readAsDataURL(f);
  e.target.value = '';
}

function applyBgToCanvas() {
  if (!bgSrc) return;
  addBgItem(bgSrc);
  showToast('✓ 背景已铺设，可选中进行缩放');
}

function addBgItem(src) {
  const existing = document.getElementById('bg-canvas-item');
  if (existing) existing.remove();

  const wrap = document.getElementById('renderCanvas');
  const el = document.createElement('div');
  el.className = 'bg-item';
  el.id = 'bg-canvas-item';
  el.style.cssText = `width:${CW}px;height:${CH}px;left:0;top:0;`;
  el.setAttribute('data-x', 0); el.setAttribute('data-y', 0);
  el.innerHTML = `<img src="${src}" alt="bg"><div class="bg-resize-handle"></div><div class="bg-item-label">BG</div>`;
  wrap.insertBefore(el, wrap.firstChild);

  interact('#bg-canvas-item')
    .draggable({
      listeners: {
        start(e) { clearActive(); e.target.classList.add('active'); },
        move(e) {
          const t = e.target;
          const x = (parseFloat(t.getAttribute('data-x'))||0) + e.dx;
          const y = (parseFloat(t.getAttribute('data-y'))||0) + e.dy;
          t.style.left = x + 'px'; t.style.top = y + 'px';
          t.setAttribute('data-x', x); t.setAttribute('data-y', y);
        }
      }
    })
    .resizable({
      edges: { right: '.bg-resize-handle', bottom: '.bg-resize-handle' },
      listeners: { move(e) { e.target.style.width = e.rect.width + 'px'; e.target.style.height = e.rect.height + 'px'; } }
    });
}

function removeBg() {
  bgSrc = null;
  document.getElementById('bgInput').value = '';
  document.getElementById('bgPreviewRow').style.display = 'none';
  const existing = document.getElementById('bg-canvas-item');
  if (existing) existing.remove();
}
function clearBridgeBg() {
  document.getElementById('bridgeBanner').style.display = 'none';
  removeBg();
}

// Asset handlers
function handleAssetUpload(e) {
  Array.from(e.target.files).forEach((file, i) => {
    const r = new FileReader();
    r.onload = ev => {
      const id = 'item_' + Date.now() + i;
      const p = { id, name: file.name.replace(/\.[^.]+$/,''), type: 'sofa', src: ev.target.result,
        x: 80 + (prods.length * 35 % 200), y: 180 + (prods.length * 45 % 300), w: 180, z: zCounter++ };
      prods.push(p);
      renderProdList();
      addCanvasItem(p);
    };
    r.readAsDataURL(file);
  });
  e.target.value = '';
}

const TYPES =[
  { val:'sofa', label:'Sofa (沙发)' },
  { val:'chair', label:'Chair (椅子)' },
  { val:'table', label:'Table (桌/茶几)' },
  { val:'bed', label:'Bed (床)' },
  { val:'cabinet', label:'Cabinet (柜子)' },
  { val:'rug', label:'Rug (地毯)' },
  { val:'chandelier', label:'Chandelier (吊灯)' },
  { val:'floor lamp', label:'Floor Lamp (落地灯)' },
  { val:'art painting', label:'Art (挂画)' },
  { val:'plant', label:'Plant (植物)' },
];

function typeOptions(current) { return TYPES.map(t => `<option value="${t.val}" ${t.val===current?'selected':''}>${t.label}</option>`).join(''); }

function renderProdList() {
  const list = document.getElementById('prodList');
  list.innerHTML = '';
  prods.forEach(p => {
    list.innerHTML += `
      <div class="prod-item">
        <img src="${p.src}">
        <div class="prod-meta">
          <input type="text" value="${p.name}" onchange="updateProd('${p.id}','name',this.value)" placeholder="Name">
          <select onchange="updateProd('${p.id}','type',this.value)">${typeOptions(p.type)}</select>
        </div>
        <button class="prod-del" onclick="removeProd('${p.id}')">×</button>
      </div>`;
  });
}

function updateProd(id, key, val) { const p = prods.find(x=>x.id===id); if(p) p[key]=val; }
function removeProd(id) {
  prods = prods.filter(x=>x.id!==id);
  renderProdList();
  const el = document.getElementById(id); if(el) el.remove();
}

function addCanvasItem(p) {
  const wrap = document.getElementById('renderCanvas');
  const el = document.createElement('div');
  el.className = 'canvas-item'; el.id = p.id;
  el.style.cssText = `width:${p.w}px;z-index:${p.z};transform:translate(${p.x}px,${p.y}px);`;
  el.setAttribute('data-x', p.x); el.setAttribute('data-y', p.y);
  el.innerHTML = `<img src="${p.src}"><div class="resize-handle"></div>`;
  wrap.appendChild(el);
}

function clearActive() {
  document.querySelectorAll('.canvas-item, .bg-item').forEach(el=>el.classList.remove('active'));
}

interact('.canvas-item')
  .draggable({
    modifiers:[interact.modifiers.restrictRect({restriction:'parent',endOnly:true})],
    listeners:{
      start(e){ clearActive(); e.target.classList.add('active'); e.target.style.zIndex = zCounter++; },
      move(e){
        const t = e.target;
        const x = (parseFloat(t.getAttribute('data-x'))||0)+e.dx;
        const y = (parseFloat(t.getAttribute('data-y'))||0)+e.dy;
        t.style.transform = `translate(${x}px,${y}px)`;
        t.setAttribute('data-x',x); t.setAttribute('data-y',y);
      }
    }
  })
  .resizable({
    edges:{right:'.resize-handle',bottom:'.resize-handle'},
    modifiers:[interact.modifiers.aspectRatio({ratio:'preserve'})],
    listeners:{move(e){e.target.style.width=e.rect.width+'px';}}
  });

document.addEventListener('pointerdown', e => {
  if(!e.target.closest('.canvas-item') && !e.target.closest('.bg-item') && !e.target.closest('.ctrl-panel')) clearActive();
});

// 构建 Prompt
function buildPrompt() {
  const style = document.getElementById('envStyle').value;
  const room = document.getElementById('envRoom').value;
  let rules = '';

  prods.forEach((p,idx) => {
    const el = document.getElementById(p.id);
    const x = parseFloat(el.getAttribute('data-x'));
    const y = parseFloat(el.getAttribute('data-y'));
    const w = parseFloat(el.style.width);
    const h = el.offsetHeight;
    const cx = x+(w/2), cy = y+(h/2);

    let hPos = 'Center';
    if(cx < CW*0.38) hPos='Left side';
    else if(cx > CW*0.62) hPos='Right side';

    let vPos = 'Midground';
    if(cy < CH*0.45) vPos='Background (further back)';
    else if(cy > CH*0.65) vPos='Foreground (close to camera)';

    const c = (p.type).toLowerCase();
    let place='';
    if(c.includes('light')||c.includes('chandelier')) place=`Hanging strictly from the ceiling in the ${hPos}.`;
    else if(c.includes('rug')) place=`Lying flat on the floor in the ${hPos}, absolute base layer.`;
    else if(c.includes('art')||c.includes('painting')) place=`Mounted flat on the wall in the ${hPos}.`;
    else place=`Placed on the floor in the ${hPos}, ${vPos}.`;

    rules += `- One ${p.name} (${p.type}). Placement: ${place}\n`;
  });

  return `Generate a highly photorealistic, architectural interior design visualization.

ENVIRONMENT & ARCHITECTURE
- Room Type: ${room}
- Interior Style & Lighting: ${style}
- Camera: Eye-level perspective, 85mm lens, photorealistic with soft global illumination and ray-traced ambient occlusion.

FURNITURE & DECOR LAYOUT (Strict constraints)
${rules}

PHYSICS & SCALE
- All items must be perfectly proportioned to each other.
- No floating objects. Grounded items must touch the floor with soft contact shadows.
- Elegant, magazine-quality interior rendering.`;
}

async function orchestrate() {
  if(!prods.length && !bgSrc){ showToast('⚠️ 请至少上传一张背景图或一件家具资产'); return; }
  if(!getApiKey()) return;
  
  clearActive();
  
  // 对于Imagen 3，由于纯文本驱动最好，我们将画布逻辑提取为高度规范的英文 prompt
  const prompt = buildPrompt();
  document.getElementById('finalPromptText').value = prompt;
  document.getElementById('promptModal').classList.add('on');
}

function closeModal() { document.getElementById('promptModal').classList.remove('on'); }
</script>
