// ══════════════════════════════════
// GEMINI API 核心通信模块 (核心重写区)
// ══════════════════════════════════
function getApiKey() {
  const key = document.getElementById('apiKeyInput').value.trim();
  if (!key) {
    showToast('⚠️ 拦截：请先在顶部导航栏输入您的 Gemini API Key');
    return null;
  }
  return key;
}

// 将 DataURL 解析为 Gemini Vision API 接受的格式
function getBase64Data(dataUrl) {
  if(!dataUrl || !dataUrl.startsWith('data:image')) return null;
  const parts = dataUrl.split(',');
  const mimeStr = parts[0].match(/:(.*?);/)[1];
  return { mimeType: mimeStr, data: parts[1] };
}

// 1. 调用 Gemini 2.5 Flash Vision 解析空间 (取代原 Claude)
async function apiAnalyzeSpace(sysPromptText, imgDataUrl_1, imgDataUrl_2) {
  const apiKey = getApiKey();
  if (!apiKey) return null;

  const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=${apiKey}`;
  
  const parts =[{ text: sysPromptText }];
  const img1 = getBase64Data(imgDataUrl_1);
  const img2 = getBase64Data(imgDataUrl_2);
  
  if (img1) parts.push({ inlineData: { mimeType: img1.mimeType, data: img1.data } });
  if (img2) parts.push({ inlineData: { mimeType: img2.mimeType, data: img2.data } });

  const payload = {
    contents:[{ role: "user", parts: parts }],
    generationConfig: { temperature: 0.3 } // 低温度保证准确识别结构
  };

  try {
    const res = await fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
    const data = await res.json();
    if (data.error) throw new Error(data.error.message);
    let resultText = data.candidates[0].content.parts[0].text;
    
    // 简单清理多余的 Markdown 代码块符号
    resultText = resultText.replace(/```(json|text)?/gi, '').replace(/```/g, '').trim();
    return resultText;
  } catch (err) {
    alert("API 视觉分析失败: " + err.message);
    return null;
  }
}

// 2. 调用 Imagen 接口渲染图片
async function apiGenerateImage(promptText, aspectRatio = "3:4") {
  const apiKey = getApiKey();
  if (!apiKey) return null;

  // 【修复点】：Google API 弃用了 001 版本。这里已更新为目前稳定的 imagen-3.0-generate-002
  // （如果你想体验最新一代模型，也可以把这里改成 "imagen-4.0-generate-001"）
  const modelName = "imagen-3.0-generate-002"; 
  const url = `https://generativelanguage.googleapis.com/v1beta/models/${modelName}:predict?key=${apiKey}`;
  
  const payload = {
    instances:[{ prompt: promptText }],
    parameters: {
      sampleCount: 1,
      aspectRatio: aspectRatio 
    }
  };

  try {
    const res = await fetch(url, { 
      method: 'POST', 
      headers: { 'Content-Type': 'application/json' }, 
      body: JSON.stringify(payload) 
    });
    const data = await res.json();
    
    // 捕获 API 层面的错误
    if (data.error) throw new Error(data.error.message);
    
    if (data.predictions && data.predictions.length > 0) {
      // 修复点2：更严谨地获取官方返回的图片格式 (MIME Type)，通常是 image/jpeg 或 image/png
      const mimeType = data.predictions[0].mimeType || "image/jpeg";
      return `data:${mimeType};base64,${data.predictions[0].bytesBase64Encoded}`;
    } else {
      throw new Error("未能生成图片，API 返回了空数据。");
    }
  } catch (err) {
    alert("Imagen 渲染失败: " + err.message);
    return null;
  }
}

// 3. 统一触发渲染流程
async function apiRenderImage(module) {
  let promptText = "";
  let resultImg = null;
  let resultBox = null;
  let ratio = "3:4"; // Imagen 3 支持 1:1, 3:4, 4:3, 16:9

  if (module === 'A') {
    promptText = document.getElementById('instrBox').value.trim();
    resultImg = document.getElementById('finalImageA');
    resultBox = document.getElementById('renderResultA');
    ratio = "4:3"; // 室内硬装通常推荐横板 4:3
  } else if (module === 'B') {
    promptText = document.getElementById('finalPromptText').value.trim();
    resultImg = document.getElementById('finalImageB');
    resultBox = document.getElementById('renderResultB');
    
    // 判断当前画布比例来设置 Imagen 比例
    if(CW > CH) ratio = "4:3";
    else if(CW === CH) ratio = "1:1";
    else ratio = "3:4";
  }

  if (!promptText) { showToast("提示词不能为空！"); return; }

  showLoader("🚀 调用 Imagen 3 模型渲染中...", "云端正在生成高精度图像，约需 10-25 秒");
  const base64Img = await apiGenerateImage(promptText, ratio);
  hideLoader();

  if (base64Img) {
    resultImg.src = base64Img;
    resultBox.style.display = 'block';
    if(module === 'A') {
      setTimeout(() => resultBox.scrollIntoView({ behavior:'smooth', block:'start' }), 100);
    }
    showToast("✓ 渲染圆满完成！(点击图片可放大查看)");
  }
}


// ══════════════════════════════════
// MODULE A — HARD DECO 逻辑
// ══════════════════════════════════
// Dropzone setup
function setupDz(zoneId, inputId, thumbId, ovId, okId) {
  const zone = document.getElementById(zoneId);
  const input = document.getElementById(inputId);
  const thumb = document.getElementById(thumbId);
  const ov = document.getElementById(ovId);
  const ok = document.getElementById(okId);

  input.addEventListener('change', e => {
    const f = e.target.files[0];
    if (!f) return;
    const r = new FileReader();
    r.onload = ev => {
      thumb.src = ev.target.result;
      thumb.style.display = 'block';
      ov.classList.add('on');
      ok.textContent = '✓ ' + f.name;
      zone.querySelector('.dz-icon') && (zone.querySelector('.dz-icon').style.display = 'none');
      zone.querySelector('.dz-title') && (zone.querySelector('.dz-title').style.display = 'none');
      zone.querySelector('.dz-sub') && (zone.querySelector('.dz-sub').style.display = 'none');
    };
    r.readAsDataURL(f);
  });

  ['dragenter','dragover'].forEach(ev => zone.addEventListener(ev, e => { e.preventDefault(); zone.classList.add('drag'); }));['dragleave','drop'].forEach(ev => zone.addEventListener(ev, e => { e.preventDefault(); zone.classList.remove('drag'); }));
  zone.addEventListener('drop', e => {
    const f = e.dataTransfer.files[0];
    if (f && f.type.startsWith('image/')) {
      const dt = new DataTransfer(); dt.items.add(f); input.files = dt.files; input.dispatchEvent(new Event('change'));
    }
  });
}
setupDz('refZone','refInput','refThumb','refOv','refOk');
setupDz('bareZone','bareInput','bareThumb','bareOv','bareOk');

function goTo(n) {
  document.querySelectorAll('.page').forEach((p,i) => p.classList.toggle('active', i === n));
  document.querySelectorAll('.sn').forEach((s,i) => {
    s.classList.toggle('active', i === n);
    s.classList.toggle('done', i < n);
  });
}

// 自动生成工作流
async function autoAnalyzeAndGenerate() {
  const refSrc = document.getElementById('refThumb').src;
  const bareSrc = document.getElementById('bareThumb').src;
  
  if (!refSrc || !bareSrc || refSrc === window.location.href || bareSrc === window.location.href) {
    showToast('⚠️ 拦截：请确保参考图和毛坯房照片均已上传完毕');
    return;
  }
  if (!getApiKey()) return; // 检查API Key

  const room = document.getElementById('roomType').value;
  const note = document.getElementById('extraNote').value.trim();
  const focus = [...document.querySelectorAll('.pill.on')].map(p => p.textContent).join(', ');
  const structs = [...document.querySelectorAll('.spill.on')].map(s => s.dataset.v);
  
  const structLines = {
    beam:'The beam above the door must be 100% completely hidden by crown molding.',
    column:'Independent structural columns must be fully wrapped in target material.',
    step:'Keep the original floor height difference/steps unchanged.',
    low:'Use thin ceiling molding as ceiling height is low.'
  };
  const structText = structs.length ? structs.map(s => structLines[s]||'').filter(Boolean).join(' ') : 'No special structural constraints.';

  // 发给 Gemini 视觉大模型的系统指令
  const sysPrompt = `You are a top-tier interior design AI assistant. I am providing TWO images via API:
1. First Image (Reference): The target interior style, materials, mood, and lighting.
2. Second Image (Bare Room): The EXACT spatial architecture and structural layout.

TASK:
Analyze the images and write a highly detailed, comprehensive English prompt (250-400 words) for an advanced Image Generator (like Imagen 3) to render the final design.

RULES FOR THE OUTPUT PROMPT:
1. SPATIAL LOCK: The room's architecture, camera angle, and structural proportions MUST match the Bare Room exactly. Explicitly list the doors and windows you observe, and state NO extra openings are permitted.
2. STYLE APPLICATION: Apply the exact colors, textures, materials, and lighting from the Reference Image.
3. CONTEXT: Room type is ${room}. Focus strongly on: ${focus}. ${note ? "User note: "+note : ""}
4. STRUCTURAL FIXES: ${structText}
5. NO FURNITURE: This is a "hard decoration" empty room visualization. State explicitly: "Completely empty room, absolutely NO furniture, NO decor items, NO plants, NO rugs."
6. FORMAT: Output ONLY the raw English text prompt. Do NOT include markdown tags, Chinese text, or conversational filler. The output should be ready to paste directly into an image generator.`;

  showLoader("AI 视觉系统正在解析图纸...", "正在提取毛坯结构拓扑与参考图材质光影特征");
  const finalPrompt = await apiAnalyzeSpace(sysPrompt, refSrc, bareSrc);
  hideLoader();

  if (finalPrompt) {
    document.getElementById('instrBox').value = finalPrompt;
    goTo(2);
  }
}

// 修正词追加逻辑
const FIXES = {
  extra_wall:`\n[CORRECTION: Remove ALL added walls. Ensure the room boundary matches the original bare room photo exactly. Keep foreground open.]`,
  extra_door:`\n[CORRECTION: Remove any door/window not present in the original structural layout. Solid walls stay solid.]`,
  layout_changed:`\n[CORRECTION: STRICTLY lock the camera perspective and wall layout. Do not alter spatial proportions.]`,
  furniture_added:`\n[CORRECTION: Remove ALL furniture, sofas, plants, rugs, and decor. Must be a 100% EMPTY bare room with only wall/floor finishes.]`
};
function appendCorrection(el) {
  const k = el.dataset.k;
  const box = document.getElementById('instrBox');
  if(box.value.indexOf(FIXES[k]) === -1) {
    box.value += FIXES[k];
    showToast('已追加修正词，您可以再次点击渲染');
  }
}

function copyInstr() {
  navigator.clipboard.writeText(document.getElementById('instrBox').value).then(() => showToast('✓ 指令已复制'));
}

// 桥接到软装模块
function sendToMoodboard() {
  const finalImgA = document.getElementById('finalImageA');
  if (!finalImgA.src || finalImgA.src === window.location.href) {
    showToast('请先生成效果图后再传入软装');
    return;
  }
